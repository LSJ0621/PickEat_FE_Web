  }),

  // Search address
  http.get(`${BASE_URL}${ENDPOINTS.USER.ADDRESS_SEARCH}`, ({ request }) => {
    const url = new URL(request.url);
    const query = url.searchParams.get('query');

    if (!query || query.length < 2) {
      return HttpResponse.json(
        { message: '검색어는 2글자 이상이어야 합니다.' },
