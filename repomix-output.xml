    it('should handle non-400 API errors', async () => {
      server.use(
        http.get(`${BASE_URL}${ENDPOINTS.MENU.RECOMMEND_PLACES}`, () => {
          return HttpResponse.json({ message: '서버 오류' }, { status: 500 });
