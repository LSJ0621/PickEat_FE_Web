    await expect(submitButton).toBeEnabled();
    await submitButton.click();
    await expect(this.page.getByRole('heading', { name: '주소 추가' })).not.toBeVisible({ timeout: TIMEOUTS.MEDIUM });
  }

  /**
   * 주소 관리 모달 닫기
