      const header = document.querySelector('header');
      expect(header).toBeInTheDocument();
    });

    it('로고가 버튼으로 렌더링되어 클릭 가능하다', () => {
      renderWithProviders(<AppHeader />, {
        preloadedState: createUnauthenticatedState(),
