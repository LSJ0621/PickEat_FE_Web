  isAiLoading: false,
  aiLoadingMenu: null as string | null,
};

let mockAiHistoryState = {
  showAiHistory: false,
  aiHistoryRecommendations: [] as unknown[],
  isAiHistoryLoading: false,
  groupedAiHistory: [] as unknown[],
