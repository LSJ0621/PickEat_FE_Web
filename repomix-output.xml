      await user.click(screen.getByText('김치찌개'));

      expect(mockHandleMenuClick).toHaveBeenCalledWith('김치찌개');
    });

    it('여러 메뉴 태그 중 하나를 클릭하면 해당 메뉴로 호출된다', async () => {
      const user = userEvent.setup();
