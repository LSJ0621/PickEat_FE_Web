    it('메시지가 중앙 정렬된다', () => {
      const { container } = render(
        <StatusPopupCard
          open={true}
          message="테스트 메시지"
          onConfirm={mockOnConfirm}
        />
      );

      const textCenter = container.querySelector('.text-center');
      expect(textCenter).toBeInTheDocument();
