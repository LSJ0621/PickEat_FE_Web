  adminPage: async ({ page }, use) => {
    await performLogin(
      page,
      TEST_ACCOUNTS.ADMIN.email,
      TEST_ACCOUNTS.ADMIN.password
    );
    await use(page);
  },
});

// expect 재export
export { expect } from '@playwright/test';
