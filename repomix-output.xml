      });

      expect(screen.getByText('홍길동님')).toBeInTheDocument();
    });

    it('사용자 주소가 표시된다', () => {
      renderWithProviders(<AppHeader />, {
        preloadedState: createAuthenticatedState({ address: '서울시 강남구' }),
