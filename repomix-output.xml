        <StatusPopupCard
          open={true}
          message="테스트 메시지"
          onConfirm={mockOnConfirm}
          confirmLabel="닫기"
        />
      );

      expect(screen.getByRole('button', { name: '닫기' })).toBeInTheDocument();
    });
  });

  describe('상호작용 테스트', () => {
    it('확인 버튼을 클릭하면 onConfirm이 호출된다', async () => {
